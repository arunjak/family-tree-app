# Copy this to .env and fill in values before deploying
# NEVER commit the actual .env file!

# --- Backend ---
JWT_SECRET=replace-with-a-random-32-char-secret-string
JWT_EXPIRATION_MS=86400000

# --- Database (set by Railway automatically if using Railway PostgreSQL plugin) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/familytree
SPRING_DATASOURCE_USERNAME=familytree_user
SPRING_DATASOURCE_PASSWORD=familytree_pass

# --- Frontend (Railway backend public URL - no trailing slash) ---
VITE_API_URL=https://your-backend.up.railway.app
