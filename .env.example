# Copy this to .env — NEVER commit the actual .env file!
# For local dev, export these in your shell before running the backend.

# ── Database (Neon) ──────────────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection Details
# Make sure to select "JDBC" format from the dropdown!
DB_URL=jdbc:postgresql://ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-40-char-secret-string-here
JWT_EXPIRATION_MS=86400000

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → copy "API Environment variable"
# It looks exactly like this format:
CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@your_cloud_name

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated. In prod, set to your Render frontend URL.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (for production build only) ─────────────────────────────────────
# Set to your Render backend URL
VITE_API_URL=https://family-tree-backend.onrender.com
